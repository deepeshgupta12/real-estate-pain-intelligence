APP_NAME=Real Estate Pain Point Intelligence API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000
API_V1_PREFIX=/api/v1
APP_VERSION=0.2.0
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5460/repi_db

SCRAPER_ENABLE_LIVE_FETCH=false
SCRAPER_FAIL_OPEN_TO_STUB=true
SCRAPER_DEFAULT_TIMEOUT_SECONDS=10
SCRAPER_MAX_RETRIES=2
SCRAPER_RETRY_BACKOFF_SECONDS=1
SCRAPER_MAX_ITEMS_PER_SOURCE=10
SCRAPER_USER_AGENT=repi-bot/0.2 (+https://localhost)
SCRAPER_REDDIT_BASE_URL=https://www.reddit.com