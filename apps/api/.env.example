APP_NAME=Real Estate Pain Point Intelligence API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000
API_V1_PREFIX=/api/v1
APP_VERSION=0.2.0
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5460/repi_db

SCRAPER_ENABLE_LIVE_FETCH=true
SCRAPER_FAIL_OPEN_TO_STUB=false
SCRAPER_DEFAULT_TIMEOUT_SECONDS=10
SCRAPER_MAX_RETRIES=2
SCRAPER_RETRY_BACKOFF_SECONDS=1
SCRAPER_MAX_ITEMS_PER_SOURCE=10
SCRAPER_USER_AGENT=repi-bot/0.2 (+https://localhost)

# Reddit Official API (PRAW) — get credentials at https://www.reddit.com/prefs/apps
# 1. Go to reddit.com/prefs/apps → click "create another app"
# 2. Choose "script" type, set redirect_uri=http://localhost:8080
# 3. Copy the client_id (under app name) and client_secret
REDDIT_API_ENABLED=false
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=repi-bot/1.0 by /u/your_reddit_username
# Optional: for script-mode auth (higher rate limits)
# REDDIT_USERNAME=your_reddit_username
# REDDIT_PASSWORD=your_reddit_password

SCRAPER_REDDIT_BASE_URL=https://www.reddit.com
SCRAPER_YOUTUBE_SEARCH_BASE_URL=https://www.youtube.com/results
SCRAPER_YOUTUBE_WATCH_BASE_URL=https://www.youtube.com/watch
SCRAPER_ITUNES_SEARCH_BASE_URL=https://itunes.apple.com/search
SCRAPER_APPLE_REVIEWS_BASE_URL=https://itunes.apple.com/rss/customerreviews
SCRAPER_PUBLIC_SOCIAL_SEARCH_BASE_URL=https://hn.algolia.com/api/v1/search
SCRAPER_REVIEW_SITES_BASE_URL=https://www.trustpilot.com/review

EXPORT_OUTPUT_DIR=./generated_exports

NOTION_ENABLE_REAL_SYNC=true
NOTION_API_BASE_URL=https://api.notion.com/v1
NOTION_API_VERSION=2022-06-28
NOTION_API_KEY=
NOTION_TIMEOUT_SECONDS=15
NOTION_MAX_RETRIES=2
NOTION_RETRY_BACKOFF_SECONDS=1
NOTION_DESTINATION_MODE=database
NOTION_DATABASE_ID=
NOTION_PARENT_PAGE_ID=
NOTION_DESTINATION_LABEL=notion_database
NOTION_TITLE_PROPERTY_NAME=Name
NOTION_STATUS_PROPERTY_NAME=Status
NOTION_PRIORITY_PROPERTY_NAME=Priority
NOTION_BRAND_PROPERTY_NAME=Brand
NOTION_SOURCE_PROPERTY_NAME=Source
NOTION_DECISION_PROPERTY_NAME=Decision
NOTION_DEFAULT_TITLE_PREFIX=REPI

EMBEDDING_PROVIDER=deterministic_hash
EMBEDDING_MODEL_NAME=hash-embedding-v1
EMBEDDING_DIMENSIONS=64
RETRIEVAL_VECTOR_DISTANCE=cosine
RETRIEVAL_SEARCH_DEFAULT_TOP_K=5

INTELLIGENCE_MODE=hybrid_llm
INTELLIGENCE_ENABLE_LLM=true
INTELLIGENCE_LLM_PROVIDER=openai
INTELLIGENCE_OPENAI_MODEL=gpt-5.4
INTELLIGENCE_LLM_TIMEOUT_SECONDS=30
INTELLIGENCE_LLM_MAX_RETRIES=2
OPENAI_API_KEY=

OBSERVABILITY_STALE_RUN_SECONDS=900
OBSERVABILITY_RECENT_FAILURE_WINDOW_MINUTES=60
OBSERVABILITY_RECENT_EVENTS_WINDOW_MINUTES=60

# Redis / ARQ background tasks
REDIS_URL=redis://localhost:6379/0
ARQ_MAX_JOBS=10
ARQ_JOB_TIMEOUT=300

# JWT Authentication (CHANGE IN PRODUCTION)
JWT_SECRET_KEY=change-me-in-production-use-256-bit-random-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Database connection pooling
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# AWS Secrets Manager (optional, for production secrets)
AWS_SECRET_ARN=
AWS_REGION=ap-south-1

# GCP Secret Manager (optional)
GCP_PROJECT_ID=